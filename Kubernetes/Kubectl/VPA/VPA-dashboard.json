          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "sum by (namespace, target_name) (\n  label_replace(\n    quantile by (namespace, workload) (0.95,\n      max_over_time(container_memory_working_set_bytes{namespace=~\"$namespace\", image!=\"\", container!=\"POD\", container!=\"\"}[$__range])\n      * on (namespace, pod) group_left(workload)\n      label_replace(\n        label_replace(\n          kube_pod_owner{namespace=~\"$namespace\"},\n          \"workload\", \"$1\", \"owner_name\", \"(.+)-[a-z0-9]+$\"\n        ),\n        \"workload\", \"$1\", \"workload\", \"^$\"\n      )\n    ),\n    \"target_name\", \"$1\", \"workload\", \"(.+)\"\n  )\n)",
          "format": "table",
